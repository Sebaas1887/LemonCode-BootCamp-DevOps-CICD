pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compile') {
            agent {
                docker {
                    image 'gradle:6.6.1-jre14-openj9'
                    reuseNode true
                }
            }
            steps {
                dir('jenkins-resources/calculator') {
                    sh 'chmod +x ./gradlew'
                    sh './gradlew compileJava'
                }
            }
        }

        stage('Unit Tests') {
            agent {
                docker {
                    image 'gradle:6.6.1-jre14-openj9'
                    reuseNode true
                }
            }
            steps {
                dir('jenkins-resources/calculator') {
                    sh 'chmod +x ./gradlew'
                    sh './gradlew test'
                }
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'jenkins-resources/calculator/build/test-results/test/*.xml'
        }
    }
}